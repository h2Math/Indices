<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>
    <h1>Minimal Test</h1>
    
    <input type="text" id="email" placeholder="Email"><br><br>
    <input type="text" id="password" placeholder="Password"><br><br>
    
    <button onclick="testClick()">Test Button (Click first)</button>
    <button onclick="signUp()">Sign Up</button>
    
    <div id="output" style="margin-top:20px; background:yellow; padding:10px;"></div>

    <script>
        // First, test if the button works at all
        function testClick() {
            document.getElementById('output').innerHTML = '✅ Button is working! JavaScript is running.';
        }
        
        // Your actual credentials - REPLACE THESE
        const SUPABASE_URL = 'https://your-project.supabase.co';
        const SUPABASE_ANON_KEY = 'your-anon-key';
        
        document.getElementById('output').innerHTML = 'Page loaded. URL: ' + SUPABASE_URL;
        
        const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
        
        async function signUp() {
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            
            document.getElementById('output').innerHTML = 'SignUp function called! Email: ' + email;
            
            if (!email || !password) {
                document.getElementById('output').innerHTML = 'Please enter email and password';
                return;
            }
            
            const { data, error } = await supabase.auth.signUp({
                email: email,
                password: password
            });
            
            if (error) {
                document.getElementById('output').innerHTML = 'Error: ' + error.message;
            } else {
                document.getElementById('output').innerHTML = 'Success! User created: ' + data.user?.email;
            }
        }
    </script>
</body>
</html>
